{
  "manifest_version": 3,
  "name": "Быстрые заметки",
  "version": "2.0.2",
  "description": "Автосохраняемый редактор заметок с заголовками, списком и отладкой",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "Создать или выбрать заметку"
  },
  "background": {
    "service_worker": "background.js"
  }
}