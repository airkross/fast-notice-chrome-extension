{
  "manifest_version": 3,
  "name": "Быстрые заметки",
  "version": "3.0.0",
  "description": "Rich Text Editor для заметок с поддержкой Markdown, HTML, JSON",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "Создать или выбрать заметку"
  },
  "background": {
    "service_worker": "background.js"
  }
}