{
  "manifest_version": 3,
  "name": "Быстрые заметки",
  "version": "3.2.1",
  "description": "Rich Text Editor для заметок с поддержкой Pell",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "Создать или выбрать заметку"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["pell.js", "pell.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
